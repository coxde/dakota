From 28bb545f8897109729e21018124004a5067d159b Mon Sep 17 00:00:00 2001
From: Jordan Petridis <jpetridis@gnome.org>
Date: Wed, 6 May 2026 15:23:09 +0300
Subject: [PATCH 2/3] gnomeos-deps/kyotocabinet: Enable debug symbols

Remove the hardcoded -g0 from the configure

This patch is also from debian

https://sources.debian.org/patches/kyotocabinet/1.2.80-2/0010-Reenable-debug-symbol.patch/

Part-of: <https://gitlab.gnome.org/GNOME/gnome-build-meta/-/merge_requests/4695>
---
 .../0010-Reenable-debug-symbol.patch          | 23 +++++++++++++++++++
 1 file changed, 23 insertions(+)
 create mode 100644 patches/kyotocabinet/0010-Reenable-debug-symbol.patch

diff --git a/patches/kyotocabinet/0010-Reenable-debug-symbol.patch b/patches/kyotocabinet/0010-Reenable-debug-symbol.patch
new file mode 100644
index 0000000000..a34ee1681b
--- /dev/null
+++ b/patches/kyotocabinet/0010-Reenable-debug-symbol.patch
@@ -0,0 +1,23 @@
+From: Boyuan Yang <byang@debian.org>
+Date: Tue, 20 Jul 2021 15:16:14 -0400
+Subject: Reenable debug symbol
+
+---
+ configure.in | 4 ++--
+ 1 file changed, 2 insertions(+), 2 deletions(-)
+
+diff --git a/configure.in b/configure.in
+index 34c9f1b..4a32912 100644
+--- a/configure.in
++++ b/configure.in
+@@ -35,8 +35,8 @@ MYDOCUMENTFILES="COPYING FOSSEXCEPTION ChangeLog doc kyotocabinet.idl"
+ MYPCFILES="kyotocabinet.pc"
+ 
+ # Building flags
+-MYCFLAGS="-Wall -ansi -pedantic -fPIC -fsigned-char -g0 -O2"
+-MYCXXFLAGS="-Wall -fPIC -fsigned-char -g0 -O2"
++MYCFLAGS="-Wall -ansi -pedantic -fPIC -fsigned-char -O2"
++MYCXXFLAGS="-Wall -fPIC -fsigned-char -O2"
+ MYCPPFLAGS="-I. -I\$(INCLUDEDIR) -I/usr/local/include"
+ MYCPPFLAGS="$MYCPPFLAGS -DNDEBUG -D_GNU_SOURCE=1"
+ MYCPPFLAGS="$MYCPPFLAGS -D_FILE_OFFSET_BITS=64 -D_REENTRANT -D__EXTENSIONS__"
-- 
GitLab


